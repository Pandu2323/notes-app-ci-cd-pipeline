# Notes App Backend - Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# Database (path to SQLite file directory)
DB_PATH=./data

# CORS - Set to your frontend URL in production
CORS_ORIGIN=http://localhost:3000

# App version (set by CI/CD pipeline)
APP_VERSION=1.0.0
